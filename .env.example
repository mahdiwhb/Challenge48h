# ============================================
# Parkshare Market Study - Environment Variables
# ============================================

# Application mode: "demo" or "production"
APP_MODE=demo

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./app/backend/data/parkshare.db

# Frontend
VITE_API_URL=http://localhost/api

# Scoring weights (sum should equal 1.0)
WEIGHT_DENSITY=0.25
WEIGHT_COLLECTIVE_HOUSING=0.25
WEIGHT_PARKING_PRESSURE=0.30
WEIGHT_MOTORIZATION=0.20

# Optional: LLM API for chatbot (leave empty for rule-based mode)
LLM_API_KEY=
LLM_API_URL=

# Pipeline
PIPELINE_SCHEDULE_CRON=0 2 * * *

# Nginx
NGINX_PORT=80
